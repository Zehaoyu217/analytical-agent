# Data home — all runtime data lives here (sessions DB, wiki, artifacts, traces).
# Default: ~/.ccagent   Production example: CCAGENT_HOME=/data/ccagent
# CCAGENT_HOME=~/.ccagent

# Application
ENVIRONMENT=development
DEBUG=true

# CORS — comma-separated list of allowed origins.
# Development default: http://localhost:5173
# Production example:  CORS_ORIGINS=https://agent.example.com,https://agent-staging.example.com
CORS_ORIGINS=http://localhost:5173

# LiteLLM proxy master key (local Ollama only — not a real secret)
LITELLM_MASTER_KEY=sk-ollama-local

# Model
DEFAULT_MODEL=qwen3.5:9b
OLLAMA_BASE_URL=http://localhost:11434
LITELLM_BASE_URL=http://localhost:4000
OPENROUTER_API_KEY=

# Sandbox
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_MEMORY_MB=2048

# DuckDB
DUCKDB_PATH=./data/duckdb/analytical.db

# Wiki
WIKI_ROOT=../knowledge/wiki
WIKI_AUTO_WRITE=true

# Context
CONTEXT_MAX_TOKENS=32768
CONTEXT_COMPACTION_THRESHOLD=0.80

# Trace subsystem
TRACE_ENABLED=1
TRACE_MODE=on_failure
# TRACE_DIR — defaults to $CCAGENT_HOME/traces; set to override
# TRACE_DIR=traces
TRACE_MAX_EVENT_SIZE_BYTES=10240
JUDGE_VARIANCE_THRESHOLD=0.10
JUDGE_VARIANCE_N=5
